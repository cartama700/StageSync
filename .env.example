# StageSync 환경변수 예시.
# 사용: `cp .env.example .env` → 값 수정 → `docker compose --env-file .env up`
# 또는 shell 에서 `export $(grep -v '^#' .env | xargs)` 후 `make run`.

# ----- 서버 기본 -------------------------------------------------------
LISTEN_ADDR=:5050
LOG_LEVEL=info                  # debug | info | warn | error
SHUTDOWN_TIMEOUT=15s            # SIGTERM 후 in-flight 요청 대기 시간
REQUEST_TIMEOUT=30s             # 개별 HTTP 요청 최대 처리 시간

# ----- 데이터베이스 ----------------------------------------------------
# 비어 있으면 inmem 모드로 자동 fallback.
# Docker compose 안에서는 호스트가 `mysql` (서비스명).
# 로컬 네이티브 실행 시에는 `127.0.0.1:3306` 로 교체.
MYSQL_DSN=root:root@tcp(mysql:3306)/stagesync?parseTime=true&loc=Local

# ----- 랭킹 (Redis) ----------------------------------------------------
# 비어 있으면 inmem leaderboard 로 graceful degrade.
# Docker compose 안에서는 `redis:6379`. 로컬 네이티브는 `127.0.0.1:6379`.
REDIS_ADDR=redis:6379

# ----- JWT 인증 -------------------------------------------------------
# AUTH_SECRET 이 비어 있으면 RequireAuth 미들웨어가 pass-through (dev 모드).
# 프로덕션은 반드시 세팅 — 예: `openssl rand -base64 48` 결과.
# 설정 시 /api/gacha/* 는 Authorization: Bearer <jwt> 필수.
AUTH_SECRET=
AUTH_TOKEN_TTL=15m

# ----- Rate Limit -----------------------------------------------------
# Token Bucket (identity = authenticated player → X-Forwarded-For → RemoteAddr).
# RATE_LIMIT_RPS=0 이면 미들웨어 pass-through.
RATE_LIMIT_RPS=10
RATE_LIMIT_BURST=20

# ----- Idempotency-Key -----------------------------------------------
# write 요청 (POST/PUT/DELETE) 에 `Idempotency-Key: <uuid>` 헤더가 있으면
# 캐시된 응답을 리플레이하여 중복 처리를 차단.
# REDIS_ADDR 설정 시 Redis (SET NX EX) 사용, 아니면 inmem (단일 프로세스).
IDEMPOTENCY_TTL=5m

# ----- Phase 19 — HP 데드락 랩 ---------------------------------------
# POST /api/battle/damage 의 구현 선택.
#   naive : SELECT ... FOR UPDATE (락 경합 재현용)
#   queue : playerID 별 단일 워커 (락 경합 제거)
BATTLE_IMPL=naive
